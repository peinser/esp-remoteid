menu "External GPIO lighting outputs"

config REMOTEID_LIGHTING_ENABLE
    bool "Enable external GPIO lighting outputs"
    default n
    help
        Enables up to five simple GPIO outputs for external lighting triggers.
        These outputs are intended to drive transistor, MOSFET, relay driver,
        or opto-isolator inputs. Do not drive aircraft lights directly from an
        ESP32 GPIO pin.

if REMOTEID_LIGHTING_ENABLE

menu "Lighting output 0"

config REMOTEID_LIGHTING_OUTPUT0_ENABLE
    bool "Enable output 0"
    default n

config REMOTEID_LIGHTING_OUTPUT0_GPIO
    int "Output 0 GPIO"
    default -1
    range -1 48
    depends on REMOTEID_LIGHTING_OUTPUT0_ENABLE

config REMOTEID_LIGHTING_OUTPUT0_ACTIVE_HIGH
    bool "Output 0 active high"
    default y
    depends on REMOTEID_LIGHTING_OUTPUT0_ENABLE

config REMOTEID_LIGHTING_OUTPUT0_OPEN_DRAIN
    bool "Output 0 open drain"
    default n
    depends on REMOTEID_LIGHTING_OUTPUT0_ENABLE

choice REMOTEID_LIGHTING_OUTPUT0_PATTERN
    prompt "Output 0 operational pattern"
    default REMOTEID_LIGHTING_OUTPUT0_PATTERN_BEACON_1HZ_SHORT
    depends on REMOTEID_LIGHTING_OUTPUT0_ENABLE

config REMOTEID_LIGHTING_OUTPUT0_PATTERN_SOLID
    bool "Solid on"

config REMOTEID_LIGHTING_OUTPUT0_PATTERN_BEACON_1HZ_SHORT
    bool "Beacon 1 Hz short flash"

config REMOTEID_LIGHTING_OUTPUT0_PATTERN_BEACON_1HZ_50
    bool "Beacon 1 Hz 50% duty"

config REMOTEID_LIGHTING_OUTPUT0_PATTERN_STROBE_SINGLE
    bool "Single strobe"

config REMOTEID_LIGHTING_OUTPUT0_PATTERN_STROBE_DOUBLE
    bool "Double strobe"

config REMOTEID_LIGHTING_OUTPUT0_PATTERN_STROBE_TRIPLE
    bool "Triple strobe"

config REMOTEID_LIGHTING_OUTPUT0_PATTERN_FAST_STROBE
    bool "Fast strobe"

endchoice

config REMOTEID_LIGHTING_OUTPUT0_PHASE_MS
    int "Output 0 pattern phase offset (ms)"
    default 0
    range 0 60000
    depends on REMOTEID_LIGHTING_OUTPUT0_ENABLE

endmenu

